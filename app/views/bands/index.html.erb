<% content_for :title, "Bands" %>

<div class="w-full">
  <div class="max-w-3xl mx-auto text-center">

    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block">
        <%= notice %>
      </p>
    <% end %>

    <h1 class="font-bold text-4xl mb-6">Bands</h1>

    <% if authenticated? %>
      <div class="mb-10">
        <%= link_to "New band",
          new_band_path,
          class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium inline-block" %>
      </div>
    <% end %>

    <div id="bands" class="space-y-6">
      <% @bands&.each do |band| %>
        <div class="text-center">
          <%= link_to band, class: "block" do %>
            <%= render band %>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
</div>

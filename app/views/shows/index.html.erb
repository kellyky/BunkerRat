<% content_for :title, "Shows" %>

<div class="w-full">
  <div class="max-w-3xl mx-auto text-center">

    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block">
        <%= notice %>
      </p>
    <% end %>

    <h1 class="font-bold text-4xl mb-6">Upcoming Shows</h1>

    <div class="mb-10">
      <%= link_to "New show",
        new_show_path,
        class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium inline-block" %>
    </div>

    <!-- FUTURE -->
    <div id="shows" class="space-y-6">

      <% @future_shows&.each do |show| %>
        <div class="text-center">
          <%= render show %>
        </div>
      <% end %>

      <!-- PAST -->
      <% if @past_shows&.any? %>
        <h2 class="font-bold text-3xl mt-12 mb-6">Past Shows</h2>

        <% @past_shows.each do |show| %>
          <div class="text-center">
            <%= render show %>
          </div>
        <% end %>
      <% end %>

    </div>
  </div>
</div>
